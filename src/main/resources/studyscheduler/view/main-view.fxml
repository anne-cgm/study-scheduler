<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            stylesheets="@../style/style.css"
            fx:controller="studyscheduler.controller.TaskController">

    <center>
        <VBox spacing="30" alignment="TOP_CENTER" style="-fx-padding: 40;">

            <!-- TÍTULO -->
            <Label text="STUDY SCHEDULER"
                   styleClass="main-title"/>

            <!-- CARDS -->
            <HBox spacing="20" alignment="CENTER">

                <VBox spacing="5" alignment="CENTER" styleClass="card">
                    <Label fx:id="totalLabel" text="0"/>
                    <Label text="TOTAL"/>
                </VBox>

                <VBox spacing="5" alignment="CENTER" styleClass="card">
                    <Label fx:id="completedLabel" text="0"/>
                    <Label text="CONCLUÍDAS"/>
                </VBox>

                <VBox spacing="5" alignment="CENTER" styleClass="card">
                    <Label fx:id="overdueLabel" text="0"/>
                    <Label text="ATRASADAS"/>
                </VBox>

            </HBox>

            <!-- ADICIONAR TAREFA (TUDO NA MESMA LINHA) -->
            <HBox spacing="15" alignment="CENTER">

                <TextField fx:id="taskField"
                           promptText="Adicionar tarefa"
                           prefWidth="220"
                           prefHeight="45"/>

                <TextField fx:id="descriptionField"
                           promptText="Adicionar descrição (opcional)"
                           prefWidth="180"
                           prefHeight="45"/>

                <DatePicker fx:id="datePicker"
                            promptText="Adicionar data de entrega"
                            prefHeight="45"/>

                <Button text="+"
                        prefWidth="50"
                        prefHeight="45"
                        onAction="#handleAddTask"/>

            </HBox>

            <!-- FILTROS -->
            <HBox spacing="15" alignment="CENTER">

                <Button text="Todas"
                        styleClass="tag-button"
                        onAction="#filterAll"/>

                <Button text="Não concluídas"
                        styleClass="tag-todo"
                        onAction="#filterTodo"/>

                <Button text="Concluídas"
                        styleClass="tag-success"
                        onAction="#filterCompleted"/>

                <Button text="Atrasadas"
                        styleClass="tag-danger"
                        onAction="#filterOverdue"/>

            </HBox>

            <!-- LISTA -->
            <VBox prefWidth="700"
                  prefHeight="420"
                  style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-padding: 25;">

                <ListView fx:id="taskList"
                          prefHeight="380"/>

            </VBox>

        </VBox>
    </center>

</BorderPane>